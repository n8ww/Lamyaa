<style>
  :root{
    --ink:#080D17;
    --panel:#0F1728;
    --panel-2:#131E33;
    --border:#1E2C44;
    --border-bright:#2C4064;
    --cyan:#4FE0C9;
    --cyan-dim:#2A6E63;
    --amber:#F2A93B;
    --red-alert:#E5573F;
    --text:#E9EEF6;
    --text-muted:#8996AC;
    --text-dim:#5A6680;
  }

  *{margin:0;padding:0;box-sizing:border-box;}

  html{scroll-behavior:smooth;}

  body{
    background:var(--ink);
    color:var(--text);
    font-family:'Inter',sans-serif;
    line-height:1.6;
    overflow-x:hidden;
    background-image:
      radial-gradient(circle at 15% 0%, rgba(79,224,201,0.06), transparent 40%),
      radial-gradient(circle at 85% 20%, rgba(242,169,59,0.04), transparent 35%);
  }

  ::selection{background:var(--cyan);color:var(--ink);}

  .mono{font-family:'JetBrains Mono',monospace;}
  .display{font-family:'Space Grotesk',sans-serif;}

  a{color:inherit;text-decoration:none;}

  /* grid backdrop */
  .grid-bg{
    position:fixed;inset:0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size:44px 44px;
    pointer-events:none;
    z-index:0;
    mask-image:radial-gradient(ellipse 80% 60% at 50% 0%, black 40%, transparent 90%);
  }

  .wrap{max-width:1080px;margin:0 auto;padding:0 28px;position:relative;z-index:1;}

  /* ===== TOP BAR ===== */
  .topbar{
    position:sticky;top:0;z-index:50;
    background:rgba(8,13,23,0.85);
    backdrop-filter:blur(10px);
    border-bottom:1px solid var(--border);
  }
  .topbar-inner{
    max-width:1080px;margin:0 auto;padding:16px 28px;
    display:flex;align-items:center;justify-content:space-between;
  }
  .brand{display:flex;align-items:center;gap:10px;font-size:14px;letter-spacing:.04em;}
  .brand-dot{width:8px;height:8px;border-radius:50%;background:var(--cyan);box-shadow:0 0 8px var(--cyan);animation:pulse 2.4s ease-in-out infinite;}
  @keyframes pulse{0%,100%{opacity:1;}50%{opacity:.35;}}
  .navlinks{display:flex;gap:26px;font-size:13px;color:var(--text-muted);}
  .navlinks a{transition:color .2s;}
  .navlinks a:hover{color:var(--cyan);}
  @media(max-width:720px){.navlinks{display:none;}}

  /* ===== HERO / CLEARANCE CARD ===== */
  .hero{padding:64px 0 40px;position:relative;}
  .eyebrow{
    display:inline-flex;align-items:center;gap:8px;
    font-size:12px;letter-spacing:.12em;text-transform:uppercase;
    color:var(--cyan);margin-bottom:22px;
  }
  .eyebrow::before{content:"";width:18px;height:1px;background:var(--cyan);}

  .card{
    position:relative;
    background:linear-gradient(155deg, var(--panel) 0%, var(--panel-2) 100%);
    border:1px solid var(--border-bright);
    border-radius:4px;
    padding:0;
    overflow:hidden;
  }
  .card::before{ /* corner marks */
    content:"";position:absolute;inset:0;pointer-events:none;
    background-image:
      linear-gradient(var(--cyan) 2px, transparent 2px),
      linear-gradient(90deg, var(--cyan) 2px, transparent 2px);
    background-size:14px 14px;
    background-position:0 0, 0 0;
    background-repeat:no-repeat;
    opacity:.55;
    width:14px;height:14px;
  }
  .corner{position:absolute;width:16px;height:16px;border:2px solid var(--cyan);opacity:.7;}
  .corner.tl{top:-2px;left:-2px;border-right:none;border-bottom:none;}
  .corner.tr{top:-2px;right:-2px;border-left:none;border-bottom:none;}
  .corner.bl{bottom:-2px;left:-2px;border-right:none;border-top:none;}
  .corner.br{bottom:-2px;right:-2px;border-left:none;border-top:none;}

  .scanline{
    position:absolute;left:0;right:0;height:2px;
    background:linear-gradient(90deg, transparent, var(--cyan), transparent);
    opacity:.7;
    animation:scan 5s linear infinite;
    filter:drop-shadow(0 0 6px var(--cyan));
  }
  @keyframes scan{0%{top:0%;}100%{top:100%;}}

  .card-grid{
    display:grid;grid-template-columns:1.5fr 1fr;
    gap:0;
  }
  @media(max-width:760px){.card-grid{grid-template-columns:1fr;}}

  .card-main{padding:44px 40px;border-right:1px solid var(--border);}
  @media(max-width:760px){.card-main{border-right:none;border-bottom:1px solid var(--border);}}

  .id-label{font-size:11px;letter-spacing:.14em;color:var(--text-dim);text-transform:uppercase;margin-bottom:6px;}
  .name{
    font-family:'Space Grotesk',sans-serif;
    font-size:clamp(32px,5vw,48px);
    font-weight:700;
    line-height:1.05;
    margin-bottom:10px;
    letter-spacing:-.01em;
  }
  .role-line{font-size:16px;color:var(--cyan);font-weight:500;margin-bottom:22px;}
  .summary-text{font-size:14.5px;color:var(--text-muted);max-width:52ch;margin-bottom:26px;}

  .status-row{display:flex;gap:10px;flex-wrap:wrap;}
  .status-chip{
    display:inline-flex;align-items:center;gap:7px;
    border:1px solid var(--border-bright);border-radius:100px;
    padding:6px 13px;font-size:12px;color:var(--text-muted);
    font-family:'JetBrains Mono',monospace;
  }
  .status-chip .sq{width:6px;height:6px;background:var(--cyan);border-radius:1px;}

  .card-side{padding:44px 32px;display:flex;flex-direction:column;gap:22px;background:rgba(0,0,0,0.15);}
  .side-field{border-bottom:1px solid var(--border);padding-bottom:16px;}
  .side-field:last-child{border-bottom:none;}
  .side-label{font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--text-dim);margin-bottom:6px;font-family:'JetBrains Mono',monospace;}
  .side-value{font-size:13.5px;color:var(--text);}
  .side-value a:hover{color:var(--cyan);}

  /* ===== SECTION HEADERS ===== */
  section{padding:64px 0;border-top:1px solid var(--border);}
  .sec-head{display:flex;align-items:baseline;gap:16px;margin-bottom:36px;}
  .sec-num{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--cyan);}
  .sec-title{font-family:'Space Grotesk',sans-serif;font-size:26px;font-weight:600;}
  .sec-rule{flex:1;height:1px;background:var(--border);}

  /* ===== EXPERIENCE ===== */
  .exp-item{
    display:grid;grid-template-columns:150px 1fr;gap:28px;
    padding:26px 0;border-bottom:1px solid var(--border);
  }
  .exp-item:last-child{border-bottom:none;}
  @media(max-width:640px){.exp-item{grid-template-columns:1fr;gap:8px;}}
  .exp-date{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--text-dim);padding-top:3px;}
  .exp-role{font-family:'Space Grotesk',sans-serif;font-size:18px;font-weight:600;margin-bottom:3px;}
  .exp-org{font-size:13.5px;color:var(--cyan);margin-bottom:14px;}
  .exp-list{list-style:none;display:flex;flex-direction:column;gap:9px;}
  .exp-list li{
    font-size:14px;color:var(--text-muted);padding-left:18px;position:relative;
  }
  .exp-list li::before{
    content:"›";position:absolute;left:0;color:var(--cyan);font-family:'JetBrains Mono',monospace;
  }

  /* ===== EDUCATION strip ===== */
  .edu-strip{
    display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;
    background:var(--panel);border:1px solid var(--border);border-radius:4px;
    padding:22px 28px;
  }
  .edu-strip .exp-role{margin-bottom:2px;}

  /* ===== CERTIFICATIONS — stamped grid ===== */
  .cert-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
  @media(max-width:760px){.cert-grid{grid-template-columns:repeat(2,1fr);}}
  @media(max-width:480px){.cert-grid{grid-template-columns:1fr;}}
  .cert{
    border:1px solid var(--border);background:var(--panel);
    border-radius:4px;padding:18px 16px;position:relative;
    transition:border-color .2s, transform .2s;
  }
  .cert:hover{border-color:var(--cyan-dim);transform:translateY(-2px);}
  .cert-index{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--text-dim);margin-bottom:10px;}
  .cert-name{font-size:13.5px;font-weight:600;margin-bottom:6px;line-height:1.35;}
  .cert-org{font-size:12px;color:var(--text-muted);}
  .cert-year{
    position:absolute;top:16px;right:14px;
    font-family:'JetBrains Mono',monospace;font-size:10.5px;
    color:var(--amber);border:1px solid rgba(242,169,59,.35);
    border-radius:100px;padding:2px 8px;
  }

  /* ===== PROJECTS — case files ===== */
  .proj{
    border:1px solid var(--border);background:var(--panel);
    border-radius:4px;padding:26px 28px;margin-bottom:16px;
  }
  .proj-head{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;margin-bottom:10px;flex-wrap:wrap;}
  .proj-title{font-family:'Space Grotesk',sans-serif;font-size:17px;font-weight:600;}
  .proj-tag{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--cyan);border:1px solid var(--cyan-dim);padding:3px 9px;border-radius:100px;white-space:nowrap;}
  .proj-desc{font-size:14px;color:var(--text-muted);max-width:70ch;}

  /* ===== SKILLS — readout ===== */
  .skill-cats{display:flex;flex-direction:column;gap:22px;}
  .skill-cat-label{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--text-dim);margin-bottom:12px;}
  .skill-tags{display:flex;flex-wrap:wrap;gap:8px;}
  .tag{
    font-family:'JetBrains Mono',monospace;font-size:12.5px;
    border:1px solid var(--border-bright);color:var(--text);
    padding:6px 12px;border-radius:3px;background:rgba(79,224,201,0.03);
  }
  .prof-skills{display:flex;flex-wrap:wrap;gap:10px;margin-top:8px;}
  .pill{font-size:12.5px;color:var(--text-muted);padding:5px 4px;}
  .pill:not(:last-child)::after{content:"·";margin-left:10px;color:var(--text-dim);}

  /* ===== LANGUAGES + INTERESTS ===== */
  .two-col{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
  @media(max-width:640px){.two-col{grid-template-columns:1fr;}}
  .mini-panel{border:1px solid var(--border);background:var(--panel);border-radius:4px;padding:22px 24px;}
  .lang-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);}
  .lang-row:last-child{border-bottom:none;}
  .lang-bar{flex:1;margin:0 16px;height:4px;background:var(--border);border-radius:2px;overflow:hidden;}
  .lang-fill{height:100%;background:var(--cyan);}

  /* ===== FOOTER / CONTACT ===== */
  footer{padding:70px 0 50px;border-top:1px solid var(--border);text-align:center;}
  .footer-title{font-family:'Space Grotesk',sans-serif;font-size:28px;font-weight:600;margin-bottom:14px;}
  .footer-sub{color:var(--text-muted);font-size:14px;margin-bottom:32px;}
  .footer-links{display:flex;justify-content:center;gap:14px;flex-wrap:wrap;}
  .btn{
    font-family:'JetBrains Mono',monospace;font-size:13px;
    border:1px solid var(--border-bright);padding:11px 20px;border-radius:3px;
    transition:all .2s;display:inline-flex;align-items:center;gap:8px;
  }
  .btn:hover{border-color:var(--cyan);color:var(--cyan);background:rgba(79,224,201,.06);}
  .btn.primary{background:var(--cyan);color:var(--ink);border-color:var(--cyan);font-weight:600;}
  .btn.primary:hover{color:var(--ink);background:#6ee9d5;}
  .foot-note{margin-top:40px;font-size:11.5px;color:var(--text-dim);font-family:'JetBrains Mono',monospace;}

  @media(prefers-reduced-motion:reduce){
    .scanline,.brand-dot{animation:none;}
  }
</style>
</head>
